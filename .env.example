# This file is only used by the backup scripts at runtime on the Pi.
# All service configuration has moved to ansible/group_vars/nas/vars.yml.
#
# The backup-restic-cloud.sh script reads IMMICH_DB_DATA_LOCATION and
# GITEA__database__PATH from this file to know which paths to skip
# (preferring logical dumps over raw DB dirs).

IMMICH_DB_DATA_LOCATION=/mnt/t7/docker/immich_postgres
GITEA__database__PATH=/data/gitea/gitea.db
