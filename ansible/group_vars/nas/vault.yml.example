# Copy to vault.yml, fill in values, then encrypt:
#   ansible-vault encrypt group_vars/nas/vault.yml
#
# To edit later:
#   ansible-vault edit group_vars/nas/vault.yml

vault_immich_db_password: "change-me-generate-with-openssl-rand-base64-32"
vault_copyparty_user: "yourusername"
vault_copyparty_pass: "yourpassword"
vault_gitea_runner_token: ""   # optional; leave empty to skip runner
vault_cf_api_token: "your_cloudflare_api_token"
vault_cf_account_id: "your_cloudflare_account_id"
vault_cf_zone_id: "your_cloudflare_zone_id"
vault_garage_rpc_secret: "change-me-generate-with-openssl-rand-hex-32"
vault_garage_webui_user: "admin"
vault_garage_webui_pass: "change-me"
vault_restic_password: "change-me-generate-with-openssl-rand-base64-32"
# Generate at: https://login.tailscale.com/admin/settings/keys
# Use an ephemeral key so the node auto-removes itself if the Pi is wiped
vault_tailscale_authkey: "tskey-auth-..."
