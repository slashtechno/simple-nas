networks:
  nas-services:
    external: true

services:
  gitea:
    image: gitea/gitea:latest
    container_name: gitea
    restart: unless-stopped
    volumes:
      - {{ gitea_data_dir }}:/data
      - /etc/localtime:/etc/localtime:ro
    environment:
      USER_UID: 1000
      USER_GID: 1000
      GITEA__server__ROOT_URL: {{ gitea_root_url }}
      GITEA__server__DOMAIN: {{ gitea_domain }}
      GITEA__server__SSH_DOMAIN: {{ gitea_ssh_domain }}
      GITEA__server__SSH_PORT: "{{ gitea_ssh_port }}"
      GITEA__database__DB_TYPE: {{ gitea_db_type }}
      GITEA__database__PATH: {{ gitea_db_path }}
      GITEA__service__DISABLE_REGISTRATION: "true"
{% if vault_gitea_runner_token %}
      GITEA_RUNNER_REGISTRATION_TOKEN: '{{ vault_gitea_runner_token | replace("$", "$$") }}'
{% endif %}
    ports:
      - "2222:22"
      - "3000:3000"
    networks:
      - nas-services

{% if vault_gitea_runner_token %}
  gitea-runner:
    image: docker.io/gitea/act_runner:nightly
    container_name: gitea-runner
    restart: unless-stopped
    environment:
      GITEA_INSTANCE_URL: "http://gitea:3000"
      GITEA_RUNNER_REGISTRATION_TOKEN: '{{ vault_gitea_runner_token | replace("$", "$$") }}'
      GITEA_RUNNER_NAME: "pi-nas-runner"
      GITEA_RUNNER_EPHEMERAL: "1"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    networks:
      - nas-services
    depends_on:
      - gitea
{% endif %}
