networks:
  nas-services:
    external: true

services:
  garage:
    image: dxflrs/garage:{{ garage_version | default('v2.3.0') }}
    container_name: garage
    restart: unless-stopped
    # --single-node (Garage v2.3+) is only needed on first deploy to auto-configure
    # the cluster layout. Ansible detects first deploy (empty meta dir) and
    # injects the flag automatically; subsequent runs omit it.
    command: ["/garage", "server"{% if garage_is_first_deploy | default(True) %}, "--single-node"{% endif %}]
    volumes:
      - {{ nas_base_dir }}/garage/garage.toml:/etc/garage.toml:ro
      - {{ garage_data_dir }}/meta:/var/lib/garage/meta
      - {{ garage_data_dir }}/data:/var/lib/garage/data
    environment:
      GARAGE_CONFIG_FILE: /etc/garage.toml
    ports:
      - "{{ garage_s3_port | default(3900) }}:{{ garage_s3_port | default(3900) }}"
      - "{{ garage_admin_port | default(3903) }}:{{ garage_admin_port | default(3903) }}"
      - "{{ garage_rpc_port | default(3901) }}:{{ garage_rpc_port | default(3901) }}"
    networks:
      - nas-services

  garage-webui:
    image: khairul169/garage-webui:latest
    container_name: garage-webui
    restart: unless-stopped
    # webui reads garage.toml to discover the admin API and S3 settings
    volumes:
      - {{ nas_base_dir }}/garage/garage.toml:/etc/garage.toml:ro
    environment:
      # Points at Garage's admin API and S3 API — both internal to the Docker network
      API_BASE_URL: "http://garage:{{ garage_admin_port | default(3903) }}"
      S3_ENDPOINT_URL: "http://garage:{{ garage_s3_port | default(3900) }}"
      CONFIG_PATH: /etc/garage.toml
      # Admin token for the v2 API — must match admin_token in garage.toml
      API_ADMIN_KEY: '{{ vault_garage_admin_token | replace("$", "$$") }}'
      # Basic auth: format is "username:bcrypt_hash" — set via vault.
      # $$ escapes the $ in bcrypt hashes so Compose doesn't try to interpolate them as variables.
      # See https://docs.docker.com/compose/compose-file/compose-file-v3/#interpolation
      AUTH_USER_PASS: '{{ vault_garage_webui_user }}:{{ vault_garage_webui_pass | password_hash("bcrypt") | replace("$", "$$") }}'
    networks:
      - nas-services
