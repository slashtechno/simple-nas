:{{ garage_s3_port | default(3900) }} {
    @options {
        method OPTIONS
    }

    # Respond to CORS preflights immediately — never forward to Garage.
    handle @options {
        header Access-Control-Allow-Origin "{{ garage_cors_allowed_origin | default('*') }}"
        header Access-Control-Allow-Methods "GET, PUT, DELETE, HEAD"
        header Access-Control-Allow-Headers "*"
        header Access-Control-Max-Age "3600"
        respond 200
    }

    # All other requests: proxy to Garage and inject CORS header on the way back.
    handle {
        reverse_proxy garage:{{ garage_s3_port | default(3900) }}
        header Access-Control-Allow-Origin "{{ garage_cors_allowed_origin | default('*') }}"
    }
}
